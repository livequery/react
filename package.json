{
    "name": "@livequery/react",
    "repository": {
        "url": "https://github.com/livequery/react"
    },
    "type": "module",
    "version": "2.0.95",
    "description": "",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist/**/*"
    ],
    "dependencies": {
        "@livequery/core": "^2.0.92",
        "rxjs": "^7.8.2"
    },
    "devDependencies": {
        "@types/react": "^19.2.14"
    },
    "peerDependencies": {
        "react": "^19.2.5"
    },
    "scripts": {
        "clean": "rm -rf dist",
        "build:js": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --sourcemap --packages=external --production",
        "build:js:prod": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --sourcemap --packages=external --production",
        "build:types": "bunx tsc -p tsconfig.build.json",
        "build": "bun run clean && bun run build:js && bun run build:types",
        "build:prod": "bun run clean && bun run build:js:prod && bun run build:types",
        "build:watch": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --sourcemap --packages=external --watch"
    },
    "author": "",
    "license": "ISC"
}
